{
  "manifest_version": 3,
  "name": "SnapFill Local Agent",
  "version": "0.2.1",
  "description": "A local encrypted vault and user-triggered form autofill agent.",
  "minimum_chrome_version": "120",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["http://127.0.0.1:5174/*", "https://docs.google.com/*"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://127.0.0.1:5174/*"],
      "js": ["bridge.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "SnapFill Local Agent",
    "default_popup": "popup.html"
  }
}
